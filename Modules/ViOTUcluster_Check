#!/usr/bin/env bash

resolve_sidecar_command() {
    local tool_name="$1"
    local script_dir
    local sidecar_candidate

    case "$tool_name" in
        viralverify)
            script_dir="$(cd "$(dirname "$0")" && pwd)"
            sidecar_candidate="${script_dir}/../../viralverify/bin/viralverify"
            ;;
        vRhyme)
            if [ -z "${CONDA_PREFIX:-}" ]; then
                return 1
            fi
            sidecar_candidate="${CONDA_PREFIX}/envs/vRhyme/bin/vRhyme"
            ;;
        *)
            return 1
            ;;
    esac

    if [ -x "$sidecar_candidate" ]; then
        echo "$sidecar_candidate"
        return 0
    fi

    return 1
}

# Function to check if a command is installed and retrieve its version
check_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        local sidecar_candidate
        if sidecar_candidate="$(resolve_sidecar_command "$1")"; then
            echo -e "[✅] $1 is available via sidecar env: $sidecar_candidate"
            return 0
        fi
    fi

    command -v "$1" >/dev/null 2>&1
    if [ $? -eq 0 ]; then
        version=""
        case "$1" in
            "checkv")
                version="$(checkv 2>&1 | grep -oP 'CheckV v\d+\.\d+\.\d+' | sed 's/CheckV v//')"
                ;;
            "dRep")
                version="$(dRep -h 2>&1 | grep -oP '\d+\.\d+\.\d+')"
                ;;
            "bwa")
                version="$(bwa 2>&1 | grep -oP '\d+\.\d+\.\d+')"
                ;;
            "virsorter")
                version="$(virsorter -h 2>&1 | grep -oP '\d+\.\d+\.\d+\.\d+')"
                ;;
            *)
                version=$("$1" --version 2>&1 | head -n 1 | grep -oP '\d+\.\d+\.\d+')
                ;;
        esac

        if [[ -n "$version" ]]; then
            echo -e "[✅] $1 is installed. Version: $version"
        else
            echo -e "[✅] $1 is installed, but version information could not be retrieved."
        fi
        return 0
    else
        echo -e "[❌] $1 is NOT installed."
        return 1
    fi
}

get_installed_version() {
    case "$1" in
        "checkv")
            checkv 2>&1 | grep -oP 'CheckV v\d+\.\d+\.\d+' | sed 's/CheckV v//'
            ;;
        "dRep")
            dRep -h 2>&1 | grep -oP '\d+\.\d+\.\d+'
            ;;
        "bwa")
            bwa 2>&1 | grep -oP '\d+\.\d+\.\d+'
            ;;
        "virsorter")
            virsorter -h 2>&1 | grep -oP '\d+\.\d+\.\d+\.\d+'
            ;;
        *)
            "$1" --version 2>&1 | head -n 1 | grep -oP '\d+\.\d+\.\d+'
            ;;
    esac
}

# Check the installation of all required dependencies
echo "Checking dependencies..."

# List of dependencies to check
dependencies=(
    "conda"
    "fastp"
    "megahit"
    "metaspades.py"
    "virsorter"
    "viralverify"
    "genomad"
    "checkv"
    "dRep"
    "vRhyme"
    "bwa"
    "sambamba"
    "coverm"
    "parallel"
    "makeblastdb"
    "blastn"
)

# Define expected versions
declare -A expected_versions
expected_versions=(
    [genomad]="1.8.0"
    [dRep]="3.5.0"
    [checkv]="1.0.3"
    [virsorter]="2.2.4"
)

# Initialize a variable to track missing dependencies
missing_dependencies=()

# Loop through each dependency and check if it's installed
for dep in "${dependencies[@]}"; do
    if check_command "$dep"; then
        if [[ -n "${expected_versions[$dep]}" ]]; then
            installed_version="$(get_installed_version "$dep")"

            if [[ "$installed_version" != "${expected_versions[$dep]}" ]]; then
                echo -e "[⚠️] $dep version mismatch: Expected ${expected_versions[$dep]}, but found $installed_version."
            fi
        fi
    else
        missing_dependencies+=("$dep")
    fi
done

# Final message based on whether all dependencies are installed
if [ ${#missing_dependencies[@]} -eq 0 ]; then
    echo -e "All dependencies are installed."
else
    echo -e "The following dependencies are missing: "
    for missing_dep in "${missing_dependencies[@]}"; do
        echo -e "  - ❌ $missing_dep"
    done
fi
